          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Great post!\",\n  \"parentCommentId\": null\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/posts/1/comments",
